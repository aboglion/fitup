{
  "redirects": [
    {
      "source": "/",
      "destination": "/app",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:file(.*\\..*)",
      "destination": "/app/:file"
    },
    {
      "source": "/(.*)",
      "destination": "/app/index.html"
    }
  ]
}